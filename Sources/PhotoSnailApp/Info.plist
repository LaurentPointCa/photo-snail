<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleIdentifier</key>
	<string>com.laurentchouinard.photo-snail</string>
	<key>CFBundleName</key>
	<string>photo-snail</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>photo-snail reads your Photos library to generate descriptions and tags for each photo using a local AI model.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>photo-snail writes AI-generated descriptions and tags back to your Photos library metadata.</string>
	<key>NSAppleEventsUsageDescription</key>
	<string>photo-snail drives Photos.app via AppleScript to write descriptions that sync via iCloud.</string>
	<key>LSUIElement</key>
	<true/>
	<!--
	  PhotoSnail only makes HTTP requests to user-configured LLM endpoints
	  (Ollama on localhost; locally-hosted OpenAI-compatible servers on
	  arbitrary LAN hostnames like *.localdomain, *.lan, raw IPs). There is
	  no other network traffic. `NSAllowsLocalNetworking` only covers .local
	  and unqualified names, so we need the broader `NSAllowsArbitraryLoads`
	  to let the user point at whatever they've set up on their LAN.
	-->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>
</dict>
</plist>
